    "@mui/material": "^9.0.0",
    "@reduxjs/toolkit": "^2.11.2",
    "framer-motion": "^12.42.2",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.79.0",
    "react-i18next": "^17.0.9",
    "react-redux": "^9.2.0",
